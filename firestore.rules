rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /custom_users/{userId} {
      allow read, write: if true;
    }
    
    match /chats/{chatId} {
      allow read, write: if true;
    }
    
    match /published/{publishId} {
      allow read, write: if true;
    }
  }
}
