# GROQ_API_KEY: Required for Groq API llama3-8b-8192 model calls.
GROQ_API_KEY=

# REPLICATE_API_TOKEN: Required for AI Video Translation & Dubbing with Replicate Models
REPLICATE_API_TOKEN=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
