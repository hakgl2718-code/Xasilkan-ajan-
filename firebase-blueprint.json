{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the application.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "photoURL": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "lastLogin": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat session containing user and assistant messages.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "title": {
          "type": "string"
        },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": {
                "type": "string",
                "enum": ["user", "assistant"]
              },
              "content": {
                "type": "string"
              }
            },
            "required": ["role", "content"]
          }
        }
      },
      "required": ["userId", "createdAt", "updatedAt", "messages"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "User profiles. Keyed by Firebase Auth UID."
    },
    "/chats/{chatId}": {
      "schema": {
        "$ref": "#/entities/Chat"
      },
      "description": "Chat sessions. Associated with a user."
    }
  }
}
